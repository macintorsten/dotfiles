#!/usr/bin/env bash

if ! command -v convert &>/dev/null; then
  echo "error: imagemagick is required (apt install imagemagick)" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  echo "Usage: tv-braille <image> [image...]" >&2
  exit 1
fi

RENDER_PGID=""

cleanup() {
  [ -n "$RENDER_PGID" ] && kill -- -"$RENDER_PGID" 2>/dev/null
  rm -f "$AWKSCRIPT"
  echo -ne '\e[?25h\e[0m\e[?1049l'
  exit 0
}
AWKSCRIPT=$(mktemp /tmp/tv_awk.XXXXXX)
trap cleanup INT TERM EXIT
cat > "$AWKSCRIPT" << 'EOF'
/^#/ { printf "\033[H"; next }
{
  split($1, coords, ",")
  x = int(coords[1]); y = int(coords[2])
  split($0, parts, ": "); split(parts[2], colors, /[(),]/)
  r = int(colors[2]); g = int(colors[3]); b = int(colors[4])
  a = (colors[5] ~ /[0-9]/) ? int(colors[5]) : 255

  PR[y%4][x] = r " " g " " b " " a

  if (y % 4 == 3 && x + 1 == cols * 2) {
    for (bx = 0; bx < cols*2; bx += 2) {
      # dot positions in the 2x4 block:
      # row 0: dot1(bx,y-3) dot4(bx+1,y-3)
      # row 1: dot2(bx,y-2) dot5(bx+1,y-2)
      # row 2: dot3(bx,y-1) dot6(bx+1,y-1)
      # row 3: dot7(bx,y)   dot8(bx+1,y)
      # bits:  0,1,2,6      3,4,5,7

      n = split(PR[0][bx],   p0l); lr0 = p0l[1]; lg0 = p0l[2]; lb0 = p0l[3]; la0 = p0l[4]
      n = split(PR[0][bx+1], p0r); rr0 = p0r[1]; rg0 = p0r[2]; rb0 = p0r[3]; ra0 = p0r[4]
      n = split(PR[1][bx],   p1l); lr1 = p1l[1]; lg1 = p1l[2]; lb1 = p1l[3]; la1 = p1l[4]
      n = split(PR[1][bx+1], p1r); rr1 = p1r[1]; rg1 = p1r[2]; rb1 = p1r[3]; ra1 = p1r[4]
      n = split(PR[2][bx],   p2l); lr2 = p2l[1]; lg2 = p2l[2]; lb2 = p2l[3]; la2 = p2l[4]
      n = split(PR[2][bx+1], p2r); rr2 = p2r[1]; rg2 = p2r[2]; rb2 = p2r[3]; ra2 = p2r[4]
      n = split(PR[3][bx],   p3l); lr3 = p3l[1]; lg3 = p3l[2]; lb3 = p3l[3]; la3 = p3l[4]
      n = split(PR[3][bx+1], p3r); rr3 = p3r[1]; rg3 = p3r[2]; rb3 = p3r[3]; ra3 = p3r[4]

      # pixel arrays: index 0-7 = dot1..dot8
      pr[0]=lr0; pg[0]=lg0; pb[0]=lb0; pa[0]=la0  # dot1 bit0  left  row0
      pr[1]=lr1; pg[1]=lg1; pb[1]=lb1; pa[1]=la1  # dot2 bit1  left  row1
      pr[2]=lr2; pg[2]=lg2; pb[2]=lb2; pa[2]=la2  # dot3 bit2  left  row2
      pr[3]=rr0; pg[3]=rg0; pb[3]=rb0; pa[3]=ra0  # dot4 bit3  right row0
      pr[4]=rr1; pg[4]=rg1; pb[4]=rb1; pa[4]=ra1  # dot5 bit4  right row1
      pr[5]=rr2; pg[5]=rg2; pb[5]=rb2; pa[5]=ra2  # dot6 bit5  right row2
      pr[6]=lr3; pg[6]=lg3; pb[6]=lb3; pa[6]=la3  # dot7 bit6  left  row3
      pr[7]=rr3; pg[7]=rg3; pb[7]=rb3; pa[7]=ra3  # dot8 bit7  right row3

      # check full transparency
      all_trans = 1
      for (i = 0; i < 8; i++) if (pa[i] >= 128) { all_trans = 0; break }
      if (all_trans) {
        printf "\033[0m "
        if (bx + 2 == cols*2) printf "\033[0m\r\n"
        continue
      }

      # luminance and average (opaque pixels only)
      lum_sum = 0; lum_cnt = 0
      for (i = 0; i < 8; i++) {
        lum[i] = 0.299*pr[i] + 0.587*pg[i] + 0.114*pb[i]
        if (pa[i] >= 128) { lum_sum += lum[i]; lum_cnt++ }
      }
      avg_lum = (lum_cnt > 0) ? lum_sum / lum_cnt : 0

      # threshold: on = bright, off = dark
      for (i = 0; i < 8; i++) {
        if (pa[i] < 128) on[i] = 0
        else             on[i] = (lum[i] >= avg_lum) ? 1 : 0
      }

      # fg = average of on-pixels; bg = average of off-pixels
      fg_r=0; fg_g=0; fg_b=0; fg_cnt=0
      bg_r=0; bg_g=0; bg_b=0; bg_cnt=0
      for (i = 0; i < 8; i++) {
        if (pa[i] < 128) continue
        if (on[i]) { fg_r+=pr[i]; fg_g+=pg[i]; fg_b+=pb[i]; fg_cnt++ }
        else        { bg_r+=pr[i]; bg_g+=pg[i]; bg_b+=pb[i]; bg_cnt++ }
      }
      if (fg_cnt == 0) {  # all off or transparent: fallback
        for (i = 0; i < 8; i++) if (pa[i] >= 128) { fg_r+=pr[i]; fg_g+=pg[i]; fg_b+=pb[i]; fg_cnt++ }
      }
      if (bg_cnt == 0) {  # all on: fallback
        for (i = 0; i < 8; i++) if (pa[i] >= 128) { bg_r+=pr[i]; bg_g+=pg[i]; bg_b+=pb[i]; bg_cnt++ }
      }
      if (fg_cnt > 0) { fg_r=int(fg_r/fg_cnt); fg_g=int(fg_g/fg_cnt); fg_b=int(fg_b/fg_cnt) }
      if (bg_cnt > 0) { bg_r=int(bg_r/bg_cnt); bg_g=int(bg_g/bg_cnt); bg_b=int(bg_b/bg_cnt) }

      # bitmask from dot layout
      bits[0]=1; bits[1]=2; bits[2]=4; bits[3]=8
      bits[4]=16; bits[5]=32; bits[6]=64; bits[7]=128
      bitmask = 0
      for (i = 0; i < 8; i++) if (on[i]) bitmask += bits[i]

      printf "\033[48;2;%d;%d;%dm\033[38;2;%d;%d;%dm%c", \
        bg_r, bg_g, bg_b, fg_r, fg_g, fg_b, 0x2800 + bitmask

      if (bx + 2 == cols*2) printf "\033[0m\r\n"
    }
    delete PR
  }
}
EOF

show_image() {
  local img="$1"
  local mime_type w h is_animated=0

  mime_type=$(file -b --mime-type "$img")
  if [[ "$mime_type" != image/* ]]; then
    echo "error: '$img' is not an image ($mime_type)" >&2
    return 1
  fi

  w=$(tput cols || echo 80)
  h=$(tput lines || echo 24)
  h=$((h - 1))

  [[ "$mime_type" == "image/gif" || "$mime_type" == "image/webp" ]] && is_animated=1

  echo -ne '\e[?25l\e[?1049h\e[2J\e[H'

  if [ $is_animated -eq 1 ]; then
    setsid bash -c \
      'convert "$1" -coalesce -resize "$2x$(($3*4))" -alpha set -background none -gravity center -extent "$2x$(($3*4))" txt:- | awk -v cols="$(($2/2))" -f "$4"' \
      -- "$img" "$w" "$h" "$AWKSCRIPT" &
    local render_pid=$!
    local pgid
    pgid=$(ps -o pgid= -p $render_pid 2>/dev/null | tr -d ' ')
    RENDER_PGID="$pgid"

    while kill -0 $render_pid 2>/dev/null; do
      if read -s -n 1 -t 0.1 2>/dev/null; then
        [ -n "$pgid" ] && kill -- -"$pgid" 2>/dev/null
        wait $render_pid 2>/dev/null
        break
      fi
    done
    RENDER_PGID=""
  else
    convert "$img" -coalesce -resize "${w}x$((h*4))" -alpha set -background none -gravity center -extent "${w}x$((h*4))" txt:- | awk -v cols="$((w/2))" -f "$AWKSCRIPT"
    read -s -n 1
  fi
}

for img in "$@"; do
  if [ ! -f "$img" ]; then
    echo "error: '$img' not found" >&2
    continue
  fi
  show_image "$img"
done
